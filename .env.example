# DayLi Environment Configuration Example
# Copy this file to .env and fill in your own keys.

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI & Data Services
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key
EXPO_PUBLIC_EDAMAM_APP_ID=your_edamam_app_id
EXPO_PUBLIC_EDAMAM_APP_KEY=your_edamam_app_key
EXPO_PUBLIC_SPOONACULAR_API_KEY=your_spoonacular_api_key

# Google OAuth Client IDs (Optional for core logic, required for Social Auth)
EXPO_PUBLIC_WEB_CLIENT_ID=your_web_client_id
EXPO_PUBLIC_IOS_CLIENT_ID=your_ios_client_id
EXPO_PUBLIC_ANDROID_CLIENT_ID=your_android_client_id
